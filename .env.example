# Lead Generator v4 — Environment Variables
# Copy this file to .env and fill in your values
# All keys are optional — the tool works fully without any paid APIs

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3001

# ─── CLI ─────────────────────────────────────────────────────────────────────
# API endpoint for CLI (default: http://localhost:3001)
LEAD_GEN_API=http://localhost:3001

# ─── Optional: Enhanced Search ───────────────────────────────────────────────
# SerpAPI — enhanced Google search results (https://serpapi.com, free tier available)
SERPAPI_KEY=

# Hunter.io — direct email finder (https://hunter.io, 25 free/month)
HUNTER_API_KEY=

# Proxycurl — LinkedIn data enrichment (https://nubela.co/proxycurl)
PROXYCURL_API_KEY=

# Apollo.io — contact database (https://apollo.io)
APOLLO_API_KEY=

# ─── Optional: AI Lead Summaries ─────────────────────────────────────────────
# OpenAI — for GPT-powered lead summaries (https://platform.openai.com)
OPENAI_API_KEY=

# ─── Optional: Notifications ─────────────────────────────────────────────────
# Slack webhook — send new lead alerts to Slack
SLACK_WEBHOOK_URL=

# ─── Optional: Email Sending ──────────────────────────────────────────────────
# SMTP credentials for sending outreach emails directly
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ─── Optional: Database ──────────────────────────────────────────────────────
# By default, data is stored in local JSON files.
# Set a MongoDB URI to switch to persistent cloud storage (future feature)
# MONGODB_URI=

# ─── Security ────────────────────────────────────────────────────────────────
# JWT secret for session tokens (auto-generated if not set)
JWT_SECRET=change-this-to-a-random-secret-string

# ─── Scraping ────────────────────────────────────────────────────────────────
# Request timeout in milliseconds (default: 8000)
SCRAPE_TIMEOUT=8000

# Max parallel enrichment workers (default: 8)
MAX_ENRICH_WORKERS=8

# Enable Redis caching for repeated searches (requires Redis running locally)
# REDIS_URL=redis://localhost:6379
